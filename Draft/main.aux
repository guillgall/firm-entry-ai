\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces State-level event-study estimates: effect of AI Geographic Exposure (AIGE) on $\log (\text  {Business Applications})$ relative to November 2022 ($t = 0$). Shaded band is the 95\,\% confidence interval based on state-clustered standard errors (56 clusters). State and month fixed effects included. The second dashed line marks May 2025 ($t = +30$, agentic AI). Coefficients are statistically insignificant throughout.}}{16}{figure.caption.15}\protected@file@percent }
\newlabel{fig:es_state}{{7}{16}{State-level event-study estimates: effect of AI Geographic Exposure (AIGE) on $\log (\text {Business Applications})$ relative to November 2022 ($t = 0$). Shaded band is the 95\,\% confidence interval based on state-clustered standard errors (56 clusters). State and month fixed effects included. The second dashed line marks May 2025 ($t = +30$, agentic AI). Coefficients are statistically insignificant throughout}{figure.caption.15}{}}
